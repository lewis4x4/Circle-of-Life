# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Agent gate assets (JSON reports may be committed for audit; ignore heavy binaries)
test-results/design-review/screenshots/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.sfdx/
.agent-mcp/
.migration-payload-*.json
.mcp-*.sql
.mcp-payload-*.json
.tmp-mig*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets (.env.local is always ignored)
.env*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# supabase CLI
supabase/.temp/

# Local IDE / agent plans (optional; keep out of shared repo unless explicitly curated)
.cursor/plans/
.omx/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
