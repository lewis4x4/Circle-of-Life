# Copy to .env.local (never commit .env.local — it is gitignored)
# Values from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Error tracking (Sentry) — optional. Leave unset to disable telemetry locally/build-time.
# NEXT_PUBLIC_SENTRY_DSN=https://public_key@o000000.ingest.sentry.io/0000000
# SENTRY_DSN=https://public_key@o000000.ingest.sentry.io/0000000
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# SENTRY_ORG=your_sentry_org_slug
# SENTRY_PROJECT=your_sentry_project_slug

# Web Push (VAPID public key only — must match Edge Function secret VAPID_PUBLIC_KEY)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_base64url

# Server-only (API routes e.g. controlled-substance co-sign verify, scripts — never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#
# Optional demo seeding identities (must already exist in auth.users):
# DEMO_ACTOR_USER_ID=00000000-0000-0000-0000-000000000000
# DEMO_FAMILY_USER_ID=00000000-0000-0000-0000-000000000000

# Client — opt-in mock charts / demo hydration on empty DB (sales demos only; leave unset for honest UAT).
# NEXT_PUBLIC_DEMO_MODE=true

# Supabase Edge Functions — set in Dashboard → Edge Functions → Secrets (not loaded by Next.js at build time).
# Required for generate-monthly-invoices cron/scheduler callers (header x-cron-secret).
# Body may use facility_id (single site) or organization_id (all active facilities); see supabase/functions/README.md.
# GENERATE_MONTHLY_INVOICES_SECRET=your_long_random_secret_here
# Edge Function exec-kpi-snapshot (Module 24 cron → exec_kpi_snapshots); set in Dashboard → Edge Functions → Secrets.
# EXEC_KPI_SNAPSHOT_SECRET=your_long_random_secret_here
# Optional but recommended for trusted server/cron callers of dispatch-push (header x-dispatch-secret).
# DISPATCH_PUSH_SECRET=your_long_random_secret_here
# Edge Function report-scheduler (Module 26 cron → report_schedules); set in Dashboard → Edge Functions → Secrets.
# REPORT_SCHEDULER_SECRET=your_long_random_secret_here
# Facility Admin Portal — facility-expiration-scanner Edge Function (header x-cron-secret); Dashboard → Edge Functions → Secrets.
# FACILITY_EXPIRATION_SCANNER_SECRET=your_long_random_secret_here
# Track C — workflow hardening (cron callers; x-cron-secret)
# AR_AGING_CHECK_SECRET=your_long_random_secret_here
# GENERATE_EMAR_SCHEDULE_SECRET=your_long_random_secret_here
# EMAR_MISSED_DOSE_SECRET=your_long_random_secret_here
# EXEC_ALERT_EVALUATOR_SECRET=your_long_random_secret_here
# Module 22 — process-referral-hl7-inbound (pending HL7 rows → MSH parse); header x-cron-secret.
# PROCESS_REFERRAL_HL7_INBOUND_SECRET=your_long_random_secret_here
# Knowledge Base Edge Functions (ingest, knowledge-agent) — Dashboard → Edge Functions → Secrets
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
#
# Module 23 — reputation Google OAuth (Next.js API routes; owner-only connect). Optional until integrations used.
# REPUTATION_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# REPUTATION_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# REPUTATION_GOOGLE_REDIRECT_URI=https://YOUR_HOST/api/reputation/oauth/google/callback
# REPUTATION_OAUTH_STATE_SECRET=your_min_16_char_random_secret_for_oauth_state_hmac
# Optional — trusted cron (Netlify scheduled function, etc.) for automated Google review import:
# REPUTATION_GOOGLE_CRON_SECRET=your_long_random_secret_here
#
# Optional — Yelp Fusion API (server-only; manual import on /admin/reputation/integrations):
# YELP_FUSION_API_KEY=your_yelp_fusion_api_key
# Optional — Yelp Partner "Respond to review" API (Bearer). If unset, posting tries YELP_FUSION_API_KEY (may 403 if Fusion-only).
# YELP_PARTNER_API_KEY=your_yelp_partner_api_key
