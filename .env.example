# Copy to .env.local (never commit .env.local — it is gitignored)
# Values from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only (Edge Functions, scripts — never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#
# Optional demo seeding identities (must already exist in auth.users):
# DEMO_ACTOR_USER_ID=00000000-0000-0000-0000-000000000000
# DEMO_FAMILY_USER_ID=00000000-0000-0000-0000-000000000000
