{
  "name": "circle-of-life",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run migrations:check && npm run check:admin-shell && npm run check:memory-care && next build",
    "build:web": "npm run build",
    "start": "next start",
    "lint": "eslint src",
    "audit:ci": "npm audit --audit-level=high",
    "check:admin-shell": "node scripts/check-admin-shell-routes.mjs",
    "check:memory-care": "node scripts/check-memory-care.mjs",
    "check:env-example": "node scripts/check-env-example.mjs",
    "check:secrets": "node scripts/check-tracked-secrets.mjs",
    "secrets:gitleaks": "node scripts/run-gitleaks.mjs",
    "migrations:check": "node scripts/check-migration-order.mjs",
    "migrations:verify:pg": "node scripts/pg-verify-migrations.mjs",
    "a11y:routes": "node scripts/a11y-axe-routes.mjs",
    "design:review": "node .agents/design-review-runner.mjs",
    "stress:test": "tsx .agents/stress-test/run.ts",
    "segment:gates": "node scripts/agent-gates/run-segment-gates.mjs",
    "demo:auth-check": "node scripts/demo/check-auth-diagnostics.mjs",
    "demo:auth-smoke": "node scripts/demo/auth-smoke.mjs",
    "demo:ops-status": "node scripts/demo/phase1-ops-status.mjs",
    "demo:web-health": "node scripts/demo/web-health.mjs",
    "demo:pilot-readiness": "node scripts/demo/pilot-readiness.mjs",
    "demo:auth-smoke:real": "node scripts/demo/authenticated-smoke.mjs",
    "demo:seed": "node scripts/demo/seed-demo-data.mjs",
    "demo:reset": "node scripts/demo/reset-demo-data.mjs",
    "demo:reseed": "npm run demo:reset && npm run demo:seed"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "playwright": "^1.51.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
